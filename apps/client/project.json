{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/client/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "cache": false,
      "command": "vite --config apps/client/vite.config.ts"
    },
    "build": {
      "cache": true,
      "command": "vite build --config apps/client/vite.config.ts",
      "outputs": ["{projectRoot}/out"]
    },
    "typecheck": {
      "cache": true,
      "command": "tsc -p apps/client/tsconfig.json --noEmit"
    }
  }
}
