{
  "name": "@bead/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/dev.ts",
    "build": "bun run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@bead/core": "workspace:*",
    "@hono/zod-validator": "^0.9.0",
    "@t3-oss/env-core": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5"
  }
}
