{
  "name": "bead",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "nx dev client",
    "dev:api": "nx dev api",
    "dev:all": "nx run-many -t dev -p client api",
    "build:client": "nx build client",
    "typecheck": "nx run-many -t typecheck",
    "build:all": "nx build client",
    "cap": "cd apps/client && cap",
    "cap:add:android": "cd apps/client && cap add android",
    "cap:sync:android": "nx build client && cd apps/client && cap sync android",
    "cap:copy:android": "nx build client && cd apps/client && cap copy android",
    "cap:open:android": "cd apps/client && cap open android",
    "lint": "biome check",
    "format": "biome format --write",
    "fix": "biome check --write",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "nx": "^23.0.1",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "intent": {
    "skills": [
      "@tanstack/db",
      "@tanstack/react-db",
      "@tanstack/router-core",
      "@tanstack/router-plugin",
      "@tanstack/virtual-file-routes"
    ]
  }
}
