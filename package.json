{
  "name": "bead",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:client": "nx dev client",
    "dev:all": "nx run-many -t dev -p client",
    "build:client": "nx build client",
    "typecheck": "nx run-many -t typecheck",
    "build:all": "nx run-many -t build -p client",
    "cap": "cd apps/client && cap",
    "cap:add:android": "cd apps/client && cap add android",
    "cap:sync:android": "nx build client && cd apps/client && cap sync android",
    "cap:copy:android": "nx build client && cd apps/client && cap copy android",
    "cap:open:android": "cd apps/client && cap open android",
    "lint": "biome check",
    "format": "biome format --write",
    "fix": "biome check --write",
    "test": "bun test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor-community/media": "^9.1.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-db": "^0.1.87",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "konva": "^10.3.0",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-konva": "^19.2.5",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "nx": "^23.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "intent": {
    "skills": [
      "@tanstack/db",
      "@tanstack/react-db",
      "@tanstack/router-core",
      "@tanstack/router-plugin",
      "@tanstack/virtual-file-routes"
    ]
  }
}
