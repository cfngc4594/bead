# Shared app URLs
VITE_API_URL=http://localhost:3000

# API server
# Comma-separated origins allowed to call the API.
PORT=3000
CORS_ORIGINS=http://localhost:5173,https://localhost

# Client analytics
# Replace with your Umami script URL and website ID in production.
VITE_UMAMI_SCRIPT_URL=
VITE_UMAMI_WEBSITE_ID=

# Marketing site links
# Replace app store URLs when Android/iOS builds are published.
VITE_SITE_GITHUB_URL=
VITE_SITE_WEB_APP_URL=http://localhost:5173/
VITE_SITE_ANDROID_URL=
VITE_SITE_IOS_URL=
